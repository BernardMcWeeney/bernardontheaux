{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bernardontheaux",
  "main": "dist-worker/worker.js",
  "compatibility_date": "2026-02-04",
  "compatibility_flags": ["nodejs_compat"],

  // Custom build: platform=node avoids browser bundles, banner polyfills require for CJS deps
  "build": {
    "command": "node build-worker.mjs"
  },

  // Static assets from Astro build output
  "assets": {
    "directory": "./dist"
  }
}
