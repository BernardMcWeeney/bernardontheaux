---
import Icon from './Icon.astro';

const navItems = [
  { href: '/', label: 'Home', icon: 'music' },
  { href: '/reviews/', label: 'Reviews', icon: 'review' },
  { href: '/gigs/', label: 'Gigs', icon: 'gig' },
  { href: '/deep-dives/', label: 'Deep Dives', icon: 'dive' },
  { href: '/playlists/', label: 'Playlists', icon: 'playlist' },
  { href: '/notes/', label: 'Notes', icon: 'note' },
  { href: '/archive/', label: 'Archive', icon: 'archive' },
  { href: '/search/', label: 'Search', icon: 'search' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <Icon name="turntable" class="brand-mark" />
      <span class="brand-main">Bernard On The Aux</span>
    </a>
    <button class="menu-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Menu">
      <Icon name="menu" class="menu-icon menu-icon--open" />
      <Icon name="x" class="menu-icon menu-icon--close" />
    </button>
    <nav id="main-nav" class="nav">
      {navItems.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
          <Icon name={item.icon} class="nav-icon" />
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const nav = document.getElementById('main-nav');

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      nav.classList.toggle('open', !open);
    });

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('open');
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.classList.contains('open')) {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('open');
        toggle.focus();
      }
    });
  }
</script>
