---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  tags?: string[];
  artist?: string;
  section?: string;
  spotifyUrl?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = 'Bernard',
  tags = [],
  artist,
  section,
  spotifyUrl,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://bernardontheaux.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image ? new URL(image, siteUrl).toString() : `${siteUrl}/og-default.svg`;

const jsonLd = type === 'article' && publishedTime
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: ogImage,
      datePublished: publishedTime.toISOString(),
      dateModified: (modifiedTime ?? publishedTime).toISOString(),
      author: {
        '@type': 'Person',
        name: author,
      },
      publisher: {
        '@type': 'Organization',
        name: 'Bernard On The Aux',
        url: siteUrl,
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
      keywords: tags.join(', '),
      ...(section && { articleSection: section }),
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Bernard On The Aux',
      description: 'A personal, passion-driven music review and listening log.',
      url: siteUrl,
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${siteUrl}/search/?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    };
---

<!-- Canonical URL -->
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content={type === 'article' && artist ? 'music.album' : type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="Bernard On The Aux" />
<meta property="og:locale" content="en_US" />

{type === 'article' && publishedTime && (
  <>
    <meta property="article:published_time" content={publishedTime.toISOString()} />
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
    <meta property="article:author" content={author} />
    {section && <meta property="article:section" content={section} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
  </>
)}

{artist && (
  <>
    <meta property="music:musician" content={artist} />
    <meta name="music:artist" content={artist} />
  </>
)}

{spotifyUrl && (
  <link rel="alternate" type="application/json+oembed" href={`https://open.spotify.com/oembed?url=${encodeURIComponent(spotifyUrl)}`} title={title} />
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
