---
import type { GetStaticPaths, Page } from 'astro';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const playlists = (await getCollection('playlists'))
    .filter((entry) => entry.data.published !== false)
    .sort((a, b) => b.data.published_on.valueOf() - a.data.published_on.valueOf());

  return paginate(playlists, { pageSize: 12 });
};

interface Props {
  page: Page;
}

const { page } = Astro.props;
---

<Layout title="Playlists | Bernard On The Aux" description="Playlists tied to posts, themes, and late-night moods.">
  <div class="container">
    <header class="page-header">
      <p class="eyebrow">Playlists</p>
      <h1>Playlists</h1>
      <p>Curated sequences tied to posts, themes, or moods.</p>
    </header>

    <div class="grid">
      {page.data.map((entry) => (
        <PostCard
          title={entry.data.title}
          href={`/playlists/${entry.slug}/`}
          meta={`${formatDate(entry.data.published_on)} • ${entry.data.platform}`}
          excerpt={entry.data.excerpt}
          label="Playlist"
          cover={entry.data.cover}
        />
      ))}
    </div>

    <Pagination
      currentPage={page.currentPage}
      totalPages={page.lastPage}
      baseUrl="/playlists/"
    />
  </div>
</Layout>
