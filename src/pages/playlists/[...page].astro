---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

export async function getStaticPaths() {
  return [{ params: { page: undefined } }];
}

const playlists = (await getCollection('playlists'))
  .filter((entry) => entry.data.published !== false)
  .sort((a, b) => b.data.published_on.valueOf() - a.data.published_on.valueOf());

const allPlatforms = [...new Set(playlists.map((p) => p.data.platform))].sort();
const allTags = [...new Set(playlists.flatMap((p) => p.data.tags ?? []))].sort();
---

<Layout title="Playlists | Bernard On The Aux" description="Playlists tied to posts, themes, and late-night moods.">
  <div class="container">
    <header class="page-header page-header-playlist">
      <p class="eyebrow">Playlists</p>
      <h1 class="title-with-icon">
        <Icon name="playlist" class="title-icon" />
        Playlists
      </h1>
      <p>Curated sequences tied to posts, themes, or moods.</p>
    </header>

    <div class="filter-bar">
      {allPlatforms.length > 1 && (
        <div class="filter-group">
          <span class="filter-label">Platform</span>
          <select class="filter-select" data-filter="platform">
            <option value="all">All</option>
            {allPlatforms.map((p) => (
              <option value={p}>{p}</option>
            ))}
          </select>
        </div>
      )}
      {allTags.length > 0 && (
        <div class="filter-group">
          <span class="filter-label">Tags</span>
          <select class="filter-select" data-filter="tag">
            <option value="all">All</option>
            {allTags.map((t) => (
              <option value={t}>{t}</option>
            ))}
          </select>
        </div>
      )}
      <span class="filter-count" id="filter-count">{playlists.length} playlists</span>
    </div>

    <div class="grid" id="filterable-grid">
      {playlists.map((entry) => (
        <div class="filterable-card" data-platform={entry.data.platform} data-tags={(entry.data.tags ?? []).join(',')}>
          <PostCard
            title={entry.data.title}
            href={`/playlists/${entry.id}/`}
            meta={`${formatDate(entry.data.published_on)} · ${entry.data.platform}`}
            excerpt={entry.data.excerpt}
            label="Playlist"
            cover={entry.data.cover}
            pillClass="pill-playlist"
          />
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  const filters: Record<string, string> = {};
  const selects = document.querySelectorAll<HTMLSelectElement>('.filter-select');
  const cards = document.querySelectorAll<HTMLElement>('.filterable-card');
  const countEl = document.getElementById('filter-count');

  selects.forEach((sel) => {
    sel.addEventListener('change', () => {
      const group = sel.dataset.filter!;
      const value = sel.value;
      if (value === 'all') { delete filters[group]; } else { filters[group] = value; }
      applyFilters();
    });
  });

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      let show = true;
      if (filters.platform) show = card.dataset.platform === filters.platform;
      if (show && filters.tag) show = (card.dataset.tags ?? '').split(',').includes(filters.tag);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) countEl.textContent = `${visible} playlist${visible !== 1 ? 's' : ''}`;
  }
</script>
