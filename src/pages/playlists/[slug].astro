---
import Layout from '../../layouts/Layout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Icon from '../../components/Icon.astro';
import PlaylistPage from '../../components/tina/PlaylistPage';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../utils/format';
import { slugifyTag } from '../../utils/tags';
import client from '../../../tina/__generated__/databaseClient';

export async function getStaticPaths() {
  const entries = await getCollection('playlists');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const slug = Astro.params.slug!;

let tinaData: any = null;
try {
  tinaData = await client.queries.playlists({ relativePath: `${slug}.md` });
} catch {}

const { Content } = await render(entry);
const tags = entry.data.tags ?? [];

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://bernardontheaux.com';
const pageUrl = `${siteUrl}/playlists/${entry.id}/`;

const musicPlaylistLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicPlaylist',
  name: entry.data.title,
  url: pageUrl,
  datePublished: entry.data.published_on.toISOString(),
  ...(entry.data.excerpt && { description: entry.data.excerpt }),
  ...(entry.data.cover && { image: new URL(entry.data.cover, siteUrl).toString() }),
  ...(entry.data.mood && { genre: entry.data.mood }),
  creator: {
    '@type': 'Person',
    name: 'Bernard',
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Playlists', item: `${siteUrl}/playlists/` },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
  ],
};
---

<Layout
  title={`${entry.data.title} | Bernard On The Aux`}
  description={entry.data.excerpt ?? 'Playlist from Bernard On The Aux.'}
  image={entry.data.cover}
  type="article"
  publishedTime={entry.data.published_on}
  tags={tags}
  section="Playlists"
  spotifyUrl={entry.data.platform === 'Spotify' ? entry.data.playlist_url : undefined}
>
  <script type="application/ld+json" set:html={JSON.stringify(musicPlaylistLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  {tinaData ? (
    <PlaylistPage
      client:only="react"
      query={tinaData.query}
      variables={tinaData.variables}
      data={tinaData.data}
    />
  ) : (
    <div class="container">
      <div class="post-layout">
        <a class="post-back" href="/playlists/">← Back to Playlists</a>

        <div class="post-banner">
          {entry.data.cover ? (
            <img src={entry.data.cover} alt={entry.data.title} />
          ) : (
            <div class="post-banner-placeholder">
              <Icon name="playlist" size={56} />
            </div>
          )}
        </div>

        <div class="post-content">
          <div class="post-main">
            <header class="post-header-detail">
              <div class="post-collection-badge badge-playlist">
                <Icon name="playlist" /> Playlist
              </div>
              <h1 class="post-title-detail">{entry.data.title}</h1>
              <div class="post-meta-strip">
                <span>{formatDate(entry.data.published_on)}</span>
                <span class="platform-badge"><Icon name="music" size={12} /> {entry.data.platform}</span>
                {entry.data.mood && <span>{entry.data.mood}</span>}
                {entry.data.duration && <span>{entry.data.duration} min</span>}
              </div>
            </header>

            {entry.data.embed_url && (
              <div class="playlist-embed">
                <iframe
                  src={entry.data.embed_url}
                  title="Playlist embed"
                  width="100%"
                  height="380"
                  loading="lazy"
                ></iframe>
              </div>
            )}

            <div class="post-body">
              <Content />
            </div>

            <RelatedPosts
              currentSlug={entry.id}
              currentCollection="playlists"
              currentTags={tags}
            />
          </div>

          <aside class="post-sidebar">
            <div class="sidebar-card">
              <p class="sidebar-card-title">Playlist Info</p>
              <div class="sidebar-item">
                <span class="sidebar-item-label">Platform</span>
                <span class="sidebar-item-value">{entry.data.platform}</span>
              </div>
              {entry.data.duration && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Duration</span>
                  <span class="sidebar-item-value">{entry.data.duration} min</span>
                </div>
              )}
              {entry.data.mood && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Mood</span>
                  <span class="sidebar-item-value">{entry.data.mood}</span>
                </div>
              )}
              <div class="sidebar-item">
                <span class="sidebar-item-label">Link</span>
                <a href={entry.data.playlist_url} class="sidebar-item-value" style="color:var(--accent);text-decoration:underline">
                  Open playlist
                </a>
              </div>
            </div>

            {tags.length > 0 && (
              <div class="sidebar-card">
                <p class="sidebar-card-title">Tags</p>
                <div class="detail-tags">
                  {tags.map((tag) => (
                    <a href={`/tags/${slugifyTag(tag)}/`} class="detail-tag">{tag}</a>
                  ))}
                </div>
              </div>
            )}
          </aside>
        </div>
      </div>
    </div>
  )}
</Layout>
