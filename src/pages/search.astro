---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Search | Bernard On The Aux"
  description="Search across all album reviews, gig diaries, deep dives, playlists, and listening notes."
>
  <div class="container">
    <header class="page-header">
      <p class="eyebrow">Search</p>
      <h1>Search</h1>
      <p>Find posts by title, artist, or tag.</p>
    </header>

    <div class="search-container">
      <input
        type="search"
        id="search-input"
        placeholder="Search posts..."
        autocomplete="off"
        autofocus
      />

      <div class="search-filters">
        <label>
          <input type="checkbox" name="collection" value="reviews" checked />
          Reviews
        </label>
        <label>
          <input type="checkbox" name="collection" value="gigs" checked />
          Gigs
        </label>
        <label>
          <input type="checkbox" name="collection" value="deep-dives" checked />
          Deep Dives
        </label>
        <label>
          <input type="checkbox" name="collection" value="playlists" checked />
          Playlists
        </label>
        <label>
          <input type="checkbox" name="collection" value="notes" checked />
          Notes
        </label>
      </div>

      <div id="search-results" class="search-results">
        <p class="search-hint">Start typing to search...</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  import Fuse from 'fuse.js';

  interface SearchItem {
    title: string;
    slug: string;
    href: string;
    collection: string;
    collectionLabel: string;
    excerpt: string;
    artist: string;
    tags: string[];
    date: string;
  }

  let searchIndex: SearchItem[] = [];
  let fuse: Fuse<SearchItem>;

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results') as HTMLDivElement;
  const collectionFilters = document.querySelectorAll<HTMLInputElement>('input[name="collection"]');

  async function initSearch() {
    try {
      const response = await fetch('/search-index.json');
      searchIndex = await response.json();

      fuse = new Fuse(searchIndex, {
        keys: [
          { name: 'title', weight: 2 },
          { name: 'artist', weight: 1.5 },
          { name: 'tags', weight: 1 },
          { name: 'excerpt', weight: 0.5 },
        ],
        threshold: 0.3,
        includeScore: true,
      });
    } catch (error) {
      console.error('Failed to load search index:', error);
      resultsContainer.innerHTML = '<p class="search-error">Failed to load search index.</p>';
    }
  }

  function getActiveCollections(): string[] {
    return Array.from(collectionFilters)
      .filter((cb) => cb.checked)
      .map((cb) => cb.value);
  }

  function formatDate(dateStr: string): string {
    return new Date(dateStr).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }

  function performSearch() {
    const query = searchInput.value.trim();
    const activeCollections = getActiveCollections();

    if (!query) {
      resultsContainer.innerHTML = '<p class="search-hint">Start typing to search...</p>';
      return;
    }

    if (!fuse) {
      resultsContainer.innerHTML = '<p class="search-hint">Loading search...</p>';
      return;
    }

    const results = fuse
      .search(query)
      .filter((result) => activeCollections.includes(result.item.collection))
      .slice(0, 20);

    if (results.length === 0) {
      resultsContainer.innerHTML = `<p class="search-no-results">No results found for "${query}"</p>`;
      return;
    }

    const html = results
      .map(
        (result) => `
          <a href="${result.item.href}" class="search-result">
            <div class="search-result-header">
              <span class="pill">${result.item.collectionLabel}</span>
              <span class="search-result-date">${formatDate(result.item.date)}</span>
            </div>
            <h3 class="search-result-title">${result.item.title}</h3>
            ${result.item.excerpt ? `<p class="search-result-excerpt">${result.item.excerpt}</p>` : ''}
            ${result.item.tags.length > 0 ? `<div class="search-result-tags">${result.item.tags.map((t) => `<span class="tag">${t}</span>`).join('')}</div>` : ''}
          </a>
        `
      )
      .join('');

    resultsContainer.innerHTML = `
      <p class="search-count">${results.length} result${results.length === 1 ? '' : 's'} for "${query}"</p>
      ${html}
    `;
  }

  // Debounce search
  let searchTimeout: ReturnType<typeof setTimeout>;
  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(performSearch, 150);
  });

  // Handle filter changes
  collectionFilters.forEach((filter) => {
    filter.addEventListener('change', performSearch);
  });

  // Initialize
  initSearch();
</script>

<style>
  .search-container {
    max-width: 640px;
  }

  #search-input {
    width: 100%;
    padding: 0.875rem 1rem;
    font-size: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s ease;
  }

  #search-input:focus {
    border-color: var(--ink);
  }

  .search-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
    padding: 0.75rem 0;
  }

  .search-filters label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--muted);
    cursor: pointer;
  }

  .search-filters input[type="checkbox"] {
    accent-color: var(--ink);
  }

  .search-results {
    margin-top: 2rem;
  }

  .search-hint,
  .search-no-results,
  .search-error {
    color: var(--muted);
    font-style: italic;
  }

  .search-count {
    font-size: 0.875rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .search-result {
    display: block;
    padding: 1.25rem;
    margin-bottom: 1rem;
    background: var(--card);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .search-result:hover {
    background: var(--line);
  }

  .search-result-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .search-result-date {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .search-result-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--ink);
  }

  .search-result-excerpt {
    margin: 0.5rem 0 0;
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .search-result-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.75rem;
  }

  .search-result-tags .tag {
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    background: var(--bg);
    border-radius: var(--radius);
    color: var(--muted);
  }
</style>
