---
import type { GetStaticPaths, Page } from 'astro';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const notes = (await getCollection('notes'))
    .filter((entry) => entry.data.published !== false)
    .sort((a, b) => b.data.listened_on.valueOf() - a.data.listened_on.valueOf());

  return paginate(notes, { pageSize: 12 });
};

interface Props {
  page: Page;
}

const { page } = Astro.props;
---

<Layout title="Listening Notes | Bernard On The Aux" description="Short listening notes and quick logs when a moment needs saving.">
  <div class="container">
    <header class="page-header">
      <p class="eyebrow">Listening notes</p>
      <h1>Notes</h1>
      <p>Short listening notes when a moment deserves saving.</p>
    </header>

    <div class="grid">
      {page.data.map((entry) => (
        <PostCard
          title={entry.data.title}
          href={`/notes/${entry.slug}/`}
          meta={formatDate(entry.data.listened_on)}
          excerpt={entry.data.excerpt}
          label="Listening note"
          cover={entry.data.cover}
        />
      ))}
    </div>

    <Pagination
      currentPage={page.currentPage}
      totalPages={page.lastPage}
      baseUrl="/notes/"
    />
  </div>
</Layout>
