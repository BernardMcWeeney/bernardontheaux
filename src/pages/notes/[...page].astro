---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

export async function getStaticPaths() {
  return [{ params: { page: undefined } }];
}

const notes = (await getCollection('notes'))
  .filter((entry) => entry.data.published !== false)
  .sort((a, b) => b.data.listened_on.valueOf() - a.data.listened_on.valueOf());

const allTags = [...new Set(notes.flatMap((n) => n.data.tags ?? []))].sort();
const allArtists = [...new Set(notes.map((n) => n.data.artist).filter(Boolean))].sort();
---

<Layout title="Listening Notes | Bernard On The Aux" description="Short listening notes and quick logs when a moment needs saving.">
  <div class="container">
    <header class="page-header page-header-note">
      <p class="eyebrow">Listening notes</p>
      <h1 class="title-with-icon">
        <Icon name="note" class="title-icon" />
        Notes
      </h1>
      <p>Short listening notes when a moment deserves saving.</p>
    </header>

    <div class="filter-bar">
      {allArtists.length > 1 && (
        <div class="filter-group">
          <span class="filter-label">Artist</span>
          <select class="filter-select" data-filter="artist">
            <option value="all">All</option>
            {allArtists.map((a) => (
              <option value={a}>{a}</option>
            ))}
          </select>
        </div>
      )}
      {allTags.length > 0 && (
        <div class="filter-group">
          <span class="filter-label">Tags</span>
          <select class="filter-select" data-filter="tag">
            <option value="all">All</option>
            {allTags.map((t) => (
              <option value={t}>{t}</option>
            ))}
          </select>
        </div>
      )}
      <span class="filter-count" id="filter-count">{notes.length} notes</span>
    </div>

    <div class="grid" id="filterable-grid">
      {notes.map((entry) => (
        <div class="filterable-card" data-artist={entry.data.artist ?? ''} data-tags={(entry.data.tags ?? []).join(',')}>
          <PostCard
            title={entry.data.title}
            href={`/notes/${entry.id}/`}
            meta={formatDate(entry.data.listened_on)}
            excerpt={entry.data.excerpt}
            label="Note"
            cover={entry.data.cover}
            pillClass="pill-note"
          />
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  const filters: Record<string, string> = {};
  const selects = document.querySelectorAll<HTMLSelectElement>('.filter-select');
  const cards = document.querySelectorAll<HTMLElement>('.filterable-card');
  const countEl = document.getElementById('filter-count');

  selects.forEach((sel) => {
    sel.addEventListener('change', () => {
      const group = sel.dataset.filter!;
      const value = sel.value;
      if (value === 'all') { delete filters[group]; } else { filters[group] = value; }
      applyFilters();
    });
  });

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      let show = true;
      if (filters.artist) show = card.dataset.artist === filters.artist;
      if (show && filters.tag) show = (card.dataset.tags ?? '').split(',').includes(filters.tag);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) countEl.textContent = `${visible} note${visible !== 1 ? 's' : ''}`;
  }
</script>
