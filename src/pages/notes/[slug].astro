---
import Layout from '../../layouts/Layout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Icon from '../../components/Icon.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../utils/format';
import { slugifyTag } from '../../utils/tags';

export async function getStaticPaths() {
  const entries = await getCollection('notes');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;

const { Content } = await render(entry);
const tags = entry.data.tags ?? [];

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://bernardontheaux.com';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Notes', item: `${siteUrl}/notes/` },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: `${siteUrl}/notes/${entry.id}/` },
  ],
};
---

<Layout
  title={`${entry.data.title} | Bernard On The Aux`}
  description={entry.data.excerpt ?? 'Listening note from Bernard On The Aux.'}
  image={entry.data.cover}
  type="article"
  publishedTime={entry.data.listened_on}
  tags={tags}
  artist={entry.data.artist}
  section="Listening Notes"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

    <div class="container">
      <div class="post-layout" style="max-width:700px">
        <a class="post-back" href="/notes/">← Back to Notes</a>

        <header class="post-header-detail">
          <div class="post-collection-badge badge-note">
            <Icon name="note" /> Listening Note
          </div>
          <h1 class="post-title-detail">{entry.data.title}</h1>
          <div class="post-meta-strip">
            <span>{formatDate(entry.data.listened_on)}</span>
            {entry.data.artist && <span>{entry.data.artist}</span>}
            {entry.data.source && <span>{entry.data.source}</span>}
          </div>
        </header>

        <div class="post-body">
          <Content />
        </div>

        {tags.length > 0 && (
          <div style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--line)">
            <div class="detail-tags">
              {tags.map((tag) => (
                <a href={`/tags/${slugifyTag(tag)}/`} class="detail-tag">{tag}</a>
              ))}
            </div>
          </div>
        )}

        <RelatedPosts
          currentSlug={entry.id}
          currentCollection="notes"
          currentTags={tags}
          currentArtist={entry.data.artist}
        />
      </div>
    </div>
</Layout>
