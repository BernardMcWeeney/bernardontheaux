---
import type { GetStaticPaths, Page } from 'astro';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const deepDives = (await getCollection('deep-dives'))
    .filter((entry) => entry.data.published !== false)
    .sort((a, b) => b.data.published_on.valueOf() - a.data.published_on.valueOf());

  return paginate(deepDives, { pageSize: 12 });
};

interface Props {
  page: Page;
}

const { page } = Astro.props;
---

<Layout title="Deep Dives | Bernard On The Aux" description="Longer reads on artists, genres, and eras worth the time.">
  <div class="container">
    <header class="page-header">
      <p class="eyebrow">Deep dives</p>
      <h1>Deep Dives</h1>
      <p>Longer reads on artists, genres, and eras that deserve a slower pace.</p>
    </header>

    <div class="grid">
      {page.data.map((entry) => (
        <PostCard
          title={entry.data.title}
          href={`/deep-dives/${entry.slug}/`}
          meta={formatDate(entry.data.published_on)}
          excerpt={entry.data.excerpt}
          label="Deep dive"
          cover={entry.data.cover}
        />
      ))}
    </div>

    <Pagination
      currentPage={page.currentPage}
      totalPages={page.lastPage}
      baseUrl="/deep-dives/"
    />
  </div>
</Layout>
