---
import Layout from '../../layouts/Layout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getCollection } from 'astro:content';
import { formatDate, formatRating } from '../../utils/format';
import { slugifyTag } from '../../utils/tags';
import { calculateReadingTime, formatReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const entries = await getCollection('reviews');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const rating = formatRating(entry.data.rating);
const tags = entry.data.tags ?? [];
const readingTime = formatReadingTime(calculateReadingTime(entry.body));
---

<Layout
  title={`${entry.data.artist} — ${entry.data.title} | Bernard On The Aux`}
  description={entry.data.excerpt ?? 'Album review from Bernard On The Aux.'}
  image={entry.data.cover}
  type="article"
  publishedTime={entry.data.review_date}
  tags={tags}
>
  <div class="container">
    <article class="post">
      <header class="post-header">
        <p class="eyebrow">Album review</p>
        <h1 class="post-title">{entry.data.artist} — {entry.data.title}</h1>
        <div class="post-meta">
          <span>{formatDate(entry.data.review_date)}</span>
          <span>{readingTime}</span>
          {entry.data.format && <span>{entry.data.format}</span>}
          {entry.data.label && <span>{entry.data.label}</span>}
          {entry.data.release_year && <span>{entry.data.release_year}</span>}
        </div>
        <div class="rating">{rating}/10</div>
      </header>

      <dl class="meta-grid">
        {entry.data.listened_on && (
          <div>
            <dt>Listened on</dt>
            <dd>{formatDate(entry.data.listened_on)}</dd>
          </div>
        )}
        {entry.data.standout_tracks && (
          <div>
            <dt>Standout tracks</dt>
            <dd>{entry.data.standout_tracks}</dd>
          </div>
        )}
        {tags.length > 0 && (
          <div>
            <dt>Tags</dt>
            <dd class="tag-list">
              {tags.map((tag) => (
                <a href={`/tags/${slugifyTag(tag)}/`} class="tag-link">{tag}</a>
              ))}
            </dd>
          </div>
        )}
      </dl>

      <div class="post-body">
        <Content />
      </div>

      <RelatedPosts
        currentSlug={entry.slug}
        currentCollection="reviews"
        currentTags={tags}
        currentArtist={entry.data.artist}
      />
    </article>
  </div>
</Layout>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-link {
    padding: 0.25rem 0.5rem;
    background: var(--card);
    border-radius: var(--radius);
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s ease;
  }

  .tag-link:hover {
    background: var(--line);
  }
</style>
