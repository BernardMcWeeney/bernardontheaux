---
import Layout from '../../layouts/Layout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Icon from '../../components/Icon.astro';
import ReviewPage from '../../components/tina/ReviewPage';
import { getCollection, render } from 'astro:content';
import { formatDate, formatRating } from '../../utils/format';
import { slugifyTag } from '../../utils/tags';
import { calculateReadingTime, formatReadingTime } from '../../utils/readingTime';
import client from '../../../tina/__generated__/client';

export async function getStaticPaths() {
  const entries = await getCollection('reviews');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const slug = Astro.params.slug!;

let tinaData: any = null;
try {
  tinaData = await client.queries.reviews({ relativePath: `${slug}.md` });
} catch {}

const { Content } = await render(entry);
const rating = formatRating(entry.data.rating);
const tags = entry.data.tags ?? [];
const readingTime = formatReadingTime(calculateReadingTime(entry.body));
const reviewType = entry.data.review_type ?? 'album';

const typeLabels: Record<string, string> = {
  album: 'Album Review',
  gig: 'Gig Review',
  artist: 'Artist Review',
  single: 'Single Review',
  ep: 'EP Review',
  film: 'Film Review',
  other: 'Review',
};
const reviewLabel = typeLabels[reviewType] ?? 'Review';
const displayTitle = entry.data.artist ? `${entry.data.artist} — ${entry.data.title}` : entry.data.title;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://bernardontheaux.com';
const pageUrl = `${siteUrl}/reviews/${entry.id}/`;

const reviewLd: Record<string, unknown> = {
  '@type': 'Review',
  author: { '@type': 'Person', name: 'Bernard' },
  datePublished: entry.data.review_date.toISOString(),
  reviewBody: entry.data.excerpt ?? '',
  reviewRating: { '@type': 'Rating', ratingValue: entry.data.rating, bestRating: 10, worstRating: 0 },
};

const schemaType = reviewType === 'gig' ? 'MusicEvent'
  : reviewType === 'artist' ? 'MusicGroup'
  : 'MusicAlbum';

const musicAlbumLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: entry.data.title,
  ...(entry.data.artist && { byArtist: { '@type': 'MusicGroup', name: entry.data.artist } }),
  ...(entry.data.release_year && { datePublished: String(entry.data.release_year) }),
  ...(entry.data.cover && { image: new URL(entry.data.cover, siteUrl).toString() }),
  ...(tags.length > 0 && { genre: tags }),
  review: reviewLd,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Reviews', item: `${siteUrl}/reviews/` },
    { '@type': 'ListItem', position: 3, name: displayTitle, item: pageUrl },
  ],
};
---

<Layout
  title={`${displayTitle} | Bernard On The Aux`}
  description={entry.data.excerpt ?? `${reviewLabel} from Bernard On The Aux.`}
  image={entry.data.cover}
  type="article"
  publishedTime={entry.data.review_date}
  tags={tags}
  artist={entry.data.artist}
  section={reviewLabel + 's'}
>
  <script type="application/ld+json" set:html={JSON.stringify(musicAlbumLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  {tinaData ? (
    <ReviewPage
      client:only="react"
      query={tinaData.query}
      variables={tinaData.variables}
      data={tinaData.data}
    />
  ) : (
    <div class="container">
      <div class="post-layout">
        <a class="post-back" href="/reviews/">← Back to Reviews</a>

        <div class="album-hero">
          <div class="album-hero-art">
            {entry.data.cover ? (
              <img src={entry.data.cover} alt={displayTitle} />
            ) : (
              <div class="album-hero-art-placeholder">
                <Icon name="review" size={56} />
              </div>
            )}
          </div>
          <div class="album-hero-info">
            <div class="album-hero-badge">
              <Icon name="review" /> {reviewLabel}
            </div>
            <h1 class="album-hero-title">{displayTitle}</h1>
            <div class="album-hero-meta">
              <span>{formatDate(entry.data.review_date)}</span>
              <span>{readingTime}</span>
              {entry.data.format && <span>{entry.data.format}</span>}
            </div>
            <div class="album-hero-rating">
              <span class="album-hero-rating-number">{rating}</span>
              <span class="album-hero-rating-suffix">/10</span>
            </div>
          </div>
        </div>

        <div class="post-content">
          <div class="post-main">
            <div class="post-body">
              <Content />
            </div>

            <RelatedPosts
              currentSlug={entry.id}
              currentCollection="reviews"
              currentTags={tags}
              currentArtist={entry.data.artist}
            />
          </div>

          <aside class="post-sidebar">
            <div class="sidebar-card">
              <p class="sidebar-card-title">{reviewLabel.replace(' Review', '')} Info</p>
              {entry.data.artist && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Artist</span>
                  <span class="sidebar-item-value">{entry.data.artist}</span>
                </div>
              )}
              {entry.data.release_year && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Year</span>
                  <span class="sidebar-item-value">{entry.data.release_year}</span>
                </div>
              )}
              {entry.data.format && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Format</span>
                  <span class="sidebar-item-value">{entry.data.format}</span>
                </div>
              )}
              {entry.data.label && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Label</span>
                  <span class="sidebar-item-value">{entry.data.label}</span>
                </div>
              )}
              {entry.data.listened_on && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Listened</span>
                  <span class="sidebar-item-value">{formatDate(entry.data.listened_on)}</span>
                </div>
              )}
            </div>

            {entry.data.standout_tracks && (
              <div class="sidebar-card">
                <p class="sidebar-card-title">Standout Tracks</p>
                <p style="margin:0;font-size:0.9rem;color:var(--ink-secondary);line-height:1.6">{entry.data.standout_tracks}</p>
              </div>
            )}

            {tags.length > 0 && (
              <div class="sidebar-card">
                <p class="sidebar-card-title">Tags</p>
                <div class="detail-tags">
                  {tags.map((tag) => (
                    <a href={`/tags/${slugifyTag(tag)}/`} class="detail-tag">{tag}</a>
                  ))}
                </div>
              </div>
            )}
          </aside>
        </div>
      </div>
    </div>
  )}
</Layout>
