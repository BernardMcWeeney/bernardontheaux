---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

export async function getStaticPaths() {
  return [{ params: { page: undefined } }];
}

const reviews = (await getCollection('reviews'))
  .filter((entry) => entry.data.published !== false)
  .sort((a, b) => b.data.review_date.valueOf() - a.data.review_date.valueOf());

const allTags = [...new Set(reviews.flatMap((r) => r.data.tags ?? []))].sort();
const allFormats = [...new Set(reviews.map((r) => r.data.format).filter(Boolean))].sort();
const allYears = [...new Set(reviews.map((r) => r.data.review_date.getFullYear()))].sort((a, b) => b - a);
---

<Layout title="Album Reviews | Bernard On The Aux" description="Album reviews with context, restraint, and full-album listening notes.">
  <div class="container">
    <header class="page-header page-header-review">
      <p class="eyebrow">Album reviews</p>
      <h1 class="title-with-icon">
        <Icon name="review" class="title-icon" />
        Reviews
      </h1>
      <p>Full-album listening notes for new releases and older records revisited.</p>
    </header>

    <div class="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Rating</span>
        <select class="filter-select" data-filter="rating">
          <option value="all">All</option>
          <option value="8+">8+</option>
          <option value="6-8">6–8</option>
          <option value="under6">&lt; 6</option>
        </select>
      </div>
      {allFormats.length > 1 && (
        <div class="filter-group">
          <span class="filter-label">Format</span>
          <select class="filter-select" data-filter="format">
            <option value="all">All</option>
            {allFormats.map((f) => (
              <option value={f}>{f}</option>
            ))}
          </select>
        </div>
      )}
      {allYears.length > 1 && (
        <div class="filter-group">
          <span class="filter-label">Year</span>
          <select class="filter-select" data-filter="year">
            <option value="all">All</option>
            {allYears.map((y) => (
              <option value={String(y)}>{y}</option>
            ))}
          </select>
        </div>
      )}
      {allTags.length > 0 && (
        <div class="filter-group">
          <span class="filter-label">Tags</span>
          <select class="filter-select" data-filter="tag">
            <option value="all">All</option>
            {allTags.map((t) => (
              <option value={t}>{t}</option>
            ))}
          </select>
        </div>
      )}
      <span class="filter-count" id="filter-count">{reviews.length} reviews</span>
    </div>

    <div class="grid" id="filterable-grid">
      {reviews.map((entry) => (
        <div
          class="filterable-card"
          data-rating={String(entry.data.rating)}
          data-format={entry.data.format ?? ''}
          data-year={String(entry.data.review_date.getFullYear())}
          data-tags={(entry.data.tags ?? []).join(',')}
        >
          <PostCard
            title={`${entry.data.artist} — ${entry.data.title}`}
            href={`/reviews/${entry.slug}/`}
            meta={formatDate(entry.data.review_date)}
            excerpt={entry.data.excerpt}
            label="Review"
            cover={entry.data.cover}
            rating={entry.data.rating}
            square={true}
            pillClass="pill-review"
          />
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  const filters: Record<string, string> = {};
  const selects = document.querySelectorAll<HTMLSelectElement>('.filter-select');
  const cards = document.querySelectorAll<HTMLElement>('.filterable-card');
  const countEl = document.getElementById('filter-count');

  selects.forEach((sel) => {
    sel.addEventListener('change', () => {
      const group = sel.dataset.filter!;
      const value = sel.value;
      if (value === 'all') { delete filters[group]; } else { filters[group] = value; }
      applyFilters();
    });
  });

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      let show = true;
      if (filters.rating) {
        const r = parseFloat(card.dataset.rating ?? '0');
        if (filters.rating === '8+') show = r >= 8;
        else if (filters.rating === '6-8') show = r >= 6 && r < 8;
        else if (filters.rating === 'under6') show = r < 6;
      }
      if (show && filters.format) show = card.dataset.format === filters.format;
      if (show && filters.year) show = card.dataset.year === filters.year;
      if (show && filters.tag) {
        const tags = (card.dataset.tags ?? '').split(',');
        show = tags.includes(filters.tag);
      }
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) countEl.textContent = `${visible} review${visible !== 1 ? 's' : ''}`;
  }
</script>
