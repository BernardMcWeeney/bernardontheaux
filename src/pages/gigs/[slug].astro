---
import Layout from '../../layouts/Layout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Icon from '../../components/Icon.astro';
import GigPage from '../../components/tina/GigPage';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../utils/format';
import { slugifyTag } from '../../utils/tags';
import client from '../../../tina/__generated__/client';

export async function getStaticPaths() {
  const entries = await getCollection('gigs');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const slug = Astro.params.slug!;

let tinaData: any = null;
try {
  tinaData = await client.queries.gigs({ relativePath: `${slug}.md` });
} catch {}

const { Content } = await render(entry);
const tags = entry.data.tags ?? [];

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://bernardontheaux.com';
const pageUrl = `${siteUrl}/gigs/${entry.id}/`;

const musicEventLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicEvent',
  name: entry.data.title,
  startDate: entry.data.event_date.toISOString(),
  location: {
    '@type': 'MusicVenue',
    name: entry.data.venue,
    address: {
      '@type': 'PostalAddress',
      addressLocality: entry.data.city,
    },
  },
  performer: {
    '@type': 'MusicGroup',
    name: entry.data.artist,
  },
  ...(entry.data.tour && { description: `${entry.data.tour}` }),
  ...(entry.data.cover && { image: new URL(entry.data.cover, siteUrl).toString() }),
  ...(entry.data.excerpt && { review: {
    '@type': 'Review',
    author: { '@type': 'Person', name: 'Bernard' },
    reviewBody: entry.data.excerpt,
  }}),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Gigs', item: `${siteUrl}/gigs/` },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
  ],
};
---

<Layout
  title={`${entry.data.title} | Bernard On The Aux`}
  description={entry.data.excerpt ?? 'Gig diary from Bernard On The Aux.'}
  image={entry.data.cover}
  type="article"
  publishedTime={entry.data.event_date}
  tags={tags}
  artist={entry.data.artist}
  section="Gig Diaries"
>
  <script type="application/ld+json" set:html={JSON.stringify(musicEventLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  {tinaData ? (
    <GigPage
      client:only="react"
      query={tinaData.query}
      variables={tinaData.variables}
      data={tinaData.data}
    />
  ) : (
    <div class="container">
      <div class="post-layout">
        <a class="post-back" href="/gigs/">← Back to Gigs</a>

        <div class="post-banner">
          {entry.data.cover ? (
            <img src={entry.data.cover} alt={entry.data.title} />
          ) : (
            <div class="post-banner-placeholder">
              <Icon name="gig" size={56} />
            </div>
          )}
        </div>

        <div class="post-content">
          <div class="post-main">
            <header class="post-header-detail">
              <div class="post-collection-badge badge-gig">
                <Icon name="gig" /> Gig Diary
              </div>
              <h1 class="post-title-detail">{entry.data.title}</h1>
              <div class="post-meta-strip">
                <span>{formatDate(entry.data.event_date)}</span>
                <span>{entry.data.venue}</span>
                <span>{entry.data.city}</span>
              </div>
            </header>

            {entry.data.highlights && (
              <div class="highlights-callout">
                <p class="highlights-callout-title">Highlights</p>
                <p>{entry.data.highlights}</p>
              </div>
            )}

            <div class="post-body">
              <Content />
            </div>

            <RelatedPosts
              currentSlug={entry.id}
              currentCollection="gigs"
              currentTags={tags}
              currentArtist={entry.data.artist}
            />
          </div>

          <aside class="post-sidebar">
            <div class="sidebar-card">
              <p class="sidebar-card-title">Event Info</p>
              <div class="sidebar-item">
                <span class="sidebar-item-label">Artist</span>
                <span class="sidebar-item-value">{entry.data.artist}</span>
              </div>
              <div class="sidebar-item">
                <span class="sidebar-item-label">Venue</span>
                <span class="sidebar-item-value">{entry.data.venue}</span>
              </div>
              <div class="sidebar-item">
                <span class="sidebar-item-label">City</span>
                <span class="sidebar-item-value">{entry.data.city}</span>
              </div>
              <div class="sidebar-item">
                <span class="sidebar-item-label">Date</span>
                <span class="sidebar-item-value">{formatDate(entry.data.event_date)}</span>
              </div>
              {entry.data.tour && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Tour</span>
                  <span class="sidebar-item-value">{entry.data.tour}</span>
                </div>
              )}
              {entry.data.support && (
                <div class="sidebar-item">
                  <span class="sidebar-item-label">Support</span>
                  <span class="sidebar-item-value">{entry.data.support}</span>
                </div>
              )}
            </div>

            {tags.length > 0 && (
              <div class="sidebar-card">
                <p class="sidebar-card-title">Tags</p>
                <div class="detail-tags">
                  {tags.map((tag) => (
                    <a href={`/tags/${slugifyTag(tag)}/`} class="detail-tag">{tag}</a>
                  ))}
                </div>
              </div>
            )}
          </aside>
        </div>
      </div>
    </div>
  )}
</Layout>
