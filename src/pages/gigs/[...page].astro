---
import type { GetStaticPaths, Page } from 'astro';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const gigs = (await getCollection('gigs'))
    .filter((entry) => entry.data.published !== false)
    .sort((a, b) => b.data.event_date.valueOf() - a.data.event_date.valueOf());

  return paginate(gigs, { pageSize: 12 });
};

interface Props {
  page: Page;
}

const { page } = Astro.props;
---

<Layout title="Gig Diaries | Bernard On The Aux" description="Concert diaries and gig reviews for shows actually attended.">
  <div class="container">
    <header class="page-header">
      <p class="eyebrow">Gig reviews</p>
      <h1>Gigs</h1>
      <p>Concert diaries for shows actually attended. The room, the set, the memory.</p>
    </header>

    <div class="grid">
      {page.data.map((entry) => (
        <PostCard
          title={entry.data.title}
          href={`/gigs/${entry.slug}/`}
          meta={`${formatDate(entry.data.event_date)} • ${entry.data.city}`}
          excerpt={entry.data.excerpt}
          label="Gig diary"
          cover={entry.data.cover}
        />
      ))}
    </div>

    <Pagination
      currentPage={page.currentPage}
      totalPages={page.lastPage}
      baseUrl="/gigs/"
    />
  </div>
</Layout>
